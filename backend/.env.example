PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio (configured in Supabase Auth dashboard, but needed for direct use)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Onfido
ONFIDO_API_TOKEN=your-onfido-token
ONFIDO_WEBHOOK_SECRET=your-webhook-secret

# HashiCorp Vault
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=dev-root-token

# AWS
AWS_REGION=eu-central-1
S3_VAULT_BUCKET=hox-vault-files

# JWT for QR share tokens
SHARE_JWT_SECRET=your-32-byte-share-secret

# Security
EGN_SALT=your-32-byte-hex-salt
